{
  "name": "<%= nameSpace %><%= tagName %>",
  "version": "1.0.0-rc.1",
  "description": "Webcomponent <%= tagName %> following open-wc recommendations",
  "keywords": [
    "lit",
    "web-component",
    "lit-element"
  ],
  "license": "MIT",
  "author": "<%= tagName %>",
  "type": "module",
  "scripts": {
    "analyze": "cem analyze --litelement --globs \"src/**/*.{js,ts}\" \"index.js\"",
    "dev:vite": "vite build",
    "prepare": "husky",
    "preview:vite": "vite preview",
    "sort:package": "npx sort-package-json",
    "start": "concurrently -k -r \"npm:vite\" \"npm:sass:watch\"",
    "test": "vitest",
    "test:watch": "vitest --browser.headless=false",
    "vite": "vite"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@blockquote/cem-to-markdown-readme": "^1.0.0",
    "@blockquote/rollup-plugin-total-bundlesize": "^2.4.0",
    "@blockquote/sass-style-template": "^5.1.1",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@open-wc/semantic-dom-diff": "^0.21.0",
    "@open-wc/testing-helpers": "^3.0.1",
    "@types/mocha": "^10.0.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "chai-a11y-axe": "^1.5.0",
    "concurrently": "^10.0.3",
    "playwright": "^1.61.1",
    "postcss-html": "^1.8.1",
    "postcss-lit": "^1.4.1",
    "rollup-plugin-node-externals": "^9.0.1",
    "sort-package-json": "^4.0.0",
    "tinyglobby": "^0.2.17",
    "vite": "^8.1.4",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "customElements": "custom-elements.json"
}
